{
  "manifest_version": 3,
  "name": "LeadHarvest AI",
  "version": "5.0.2",
  "description": "Intelligent lead extractor for Google Maps — detail-panel scraping, website email discovery, Google Ads detection, CMS/platform fingerprinting, and local-first storage. No external accounts required.",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://maps.google.com/*"
      ],
      "js": ["src/lib/storage.js", "src/content/maps-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "LeadHarvest AI",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "chrome_url_overrides": {
    "newtab": "src/queue/queue-manager.html"
  },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
