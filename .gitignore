```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Editors
.vscode/
.idea/

# Logs and temp files
*.log
*.tmp
*.swp

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution / packaging
dist/
build/
*.egg-info/

# Testing
.mypy_cache/
.pytest_cache/

# Compression artifacts
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```